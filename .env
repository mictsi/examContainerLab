# .env — parameters for docker-compose.yml (read automatically by docker compose;
# run.sh sources it too, so the printed login token stays in sync).
# Demo defaults — change JUPYTER_TOKEN before a real exam.

# Login token students enter in the browser (both labs)
JUPYTER_TOKEN=exam-demo

# Container names
CONTAINER_NAME=examlab
CONTAINER_NAME_PYTHON=examlab-python
CONTAINER_NAME_HUB=examhub

# Hub: stop + remove a student's container after this many seconds without
# activity (student work in results/<username>/ is kept; next login respawns)
IDLE_TIMEOUT=3600

# Host path of this repo, used by the hub for per-student bind mounts.
# Defaults to $PWD (correct when starting via run.sh or from the repo root);
# set explicitly if you run docker compose from somewhere else.
# EXAM_HOST_DIR=/absolute/path/to/examContainer
