# .env — parameters for docker-compose.yml (read automatically by docker compose;
# run.sh sources it too, so the printed login token stays in sync).
# Demo defaults — change JUPYTER_TOKEN before a real exam.

# Login token students enter in the browser (both labs)
JUPYTER_TOKEN=exam-demo

# Container names
CONTAINER_NAME=examlab
CONTAINER_NAME_PYTHON=examlab-python
